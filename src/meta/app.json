{
  "id": "tasklist",
  "name": "Taskboards",
  "version": {
    "major": 1,
    "minor": 0,
    "dev": 13
  },
  "author": "Matthew Morgan",
  "contactEmail": "matthew@morgantech.info",
  "description": "Collaborative checklisting application with sections, assignments, and notifications",
  "requiredPermissions": [],
  "dependencies": {},
  "tables": [
    {
      "name": "checklist",
      "description": "A named checklist with sections and items",
      "fields": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Name of the checklist"
        },
        {
          "name": "description",
          "type": "string",
          "description": "Optional description of the checklist"
        },
        {
          "name": "ownerId",
          "type": "relationship",
          "relatedTo": "system:users",
          "required": true,
          "description": "User who owns the checklist"
        }
      ]
    },
    {
      "name": "section",
      "description": "A section within a checklist",
      "fields": [
        {
          "name": "checklistId",
          "type": "relationship",
          "relatedTo": "checklist",
          "required": true,
          "description": "Parent checklist"
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "Section name"
        },
        {
          "name": "order",
          "type": "number",
          "required": true,
          "description": "Display order within the checklist"
        }
      ]
    },
    {
      "name": "item",
      "description": "An item within a checklist section",
      "fields": [
        {
          "name": "sectionId",
          "type": "relationship",
          "relatedTo": "section",
          "required": true,
          "description": "Parent section"
        },
        {
          "name": "checklistId",
          "type": "relationship",
          "relatedTo": "checklist",
          "required": true,
          "description": "Parent checklist (denormalized for queries)"
        },
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "Item title"
        },
        {
          "name": "assigneeId",
          "type": "relationship",
          "relatedTo": "system:users",
          "description": "Assigned user"
        },
        {
          "name": "dueDate",
          "type": "string",
          "description": "ISO date (e.g. 2026-03-15) or custom text for reusable items (e.g. EOM, 1st)"
        },
        {
          "name": "reusable",
          "type": "boolean",
          "description": "If true, item stays visible after completion"
        },
        {
          "name": "complete",
          "type": "boolean",
          "description": "Whether the item is checked off"
        },
        {
          "name": "order",
          "type": "number",
          "description": "Display order within the complete or incomplete group in a section"
        }
      ]
    },
    {
      "name": "ics_link",
      "description": "A calendar feed link for a checklist, authenticated by a secret token",
      "fields": [
        {
          "name": "checklistId",
          "type": "relationship",
          "relatedTo": "checklist",
          "required": true,
          "description": "Checklist this link feeds"
        },
        {
          "name": "name",
          "type": "string",
          "required": true,
          "description": "User-defined label for this link"
        },
        {
          "name": "description",
          "type": "string",
          "description": "Optional description of where this link is used"
        },
        {
          "name": "tokenHash",
          "type": "string",
          "required": true,
          "description": "SHA-256 hash of the secret token embedded in the feed URL"
        },
        {
          "name": "createdBy",
          "type": "relationship",
          "relatedTo": "system:users",
          "required": true,
          "description": "User who created the link"
        },
        {
          "name": "createdAt",
          "type": "string",
          "required": true,
          "description": "ISO 8601 creation timestamp"
        }
      ]
    },
    {
      "name": "subscription",
      "description": "A user notification subscription for a checklist or item",
      "fields": [
        {
          "name": "userId",
          "type": "relationship",
          "relatedTo": "system:users",
          "required": true,
          "description": "Subscribing user"
        },
        {
          "name": "checklistId",
          "type": "relationship",
          "relatedTo": "checklist",
          "description": "Checklist being watched (set when watching an entire checklist)"
        },
        {
          "name": "itemId",
          "type": "relationship",
          "relatedTo": "item",
          "description": "Item being watched (set when watching a specific item)"
        }
      ]
    }
  ],
  "authorizations": [
    {
      "id": "checklist-editor",
      "name": "Checklist Editor Access",
      "description": "Grants edit access to a shared checklist",
      "contextual": true
    },
    {
      "id": "checklist-viewer",
      "name": "Checklist Viewer Access",
      "description": "Grants view access to a shared checklist",
      "contextual": true
    }
  ],
  "authorities": [
    {
      "id": "checklist-editor",
      "name": "Checklist Editor",
      "authorizations": ["tasklist:checklist-editor"]
    },
    {
      "id": "checklist-viewer",
      "name": "Checklist Viewer",
      "authorizations": ["tasklist:checklist-viewer"]
    }
  ],
  "apiRoutes": [
    {
      "path": "checklists",
      "method": "GET",
      "description": "List all checklists the user owns or has access to"
    },
    {
      "path": "checklists",
      "method": "POST",
      "description": "Create a new checklist"
    },
    {
      "path": "checklists/[checklist-id]",
      "method": "GET",
      "description": "Get a checklist with all sections and items"
    },
    {
      "path": "checklists/[checklist-id]",
      "method": "PATCH",
      "description": "Update checklist name or description"
    },
    {
      "path": "checklists/[checklist-id]",
      "method": "DELETE",
      "description": "Delete a checklist (owner only)"
    },
    {
      "path": "checklists/[checklist-id]/sections",
      "method": "POST",
      "description": "Add a new section to a checklist"
    },
    {
      "path": "checklists/[checklist-id]/sections/reorder",
      "method": "POST",
      "description": "Reorder sections within a checklist"
    },
    {
      "path": "checklists/[checklist-id]/shares",
      "method": "GET",
      "description": "List all shares for a checklist"
    },
    {
      "path": "checklists/[checklist-id]/shares",
      "method": "POST",
      "description": "Share a checklist with a user"
    },
    {
      "path": "checklists/[checklist-id]/shares/[share-id]",
      "method": "PATCH",
      "description": "Update a share role"
    },
    {
      "path": "checklists/[checklist-id]/shares/[share-id]",
      "method": "DELETE",
      "description": "Remove a share"
    },
    {
      "path": "checklists/[checklist-id]/subscriptions",
      "method": "GET",
      "description": "Get current user subscriptions for a checklist"
    },
    {
      "path": "sections/[section-id]",
      "method": "PATCH",
      "description": "Rename a section"
    },
    {
      "path": "sections/[section-id]",
      "method": "DELETE",
      "description": "Delete a section and its items"
    },
    {
      "path": "sections/[section-id]/items",
      "method": "POST",
      "description": "Add an item to a section"
    },
    {
      "path": "sections/[section-id]/items/reorder",
      "method": "POST",
      "description": "Reorder items within a section group"
    },
    {
      "path": "items/[item-id]",
      "method": "PATCH",
      "description": "Update an item"
    },
    {
      "path": "items/[item-id]",
      "method": "DELETE",
      "description": "Delete an item"
    },
    {
      "path": "subscriptions",
      "method": "POST",
      "description": "Subscribe to a checklist or item"
    },
    {
      "path": "subscriptions/[subscription-id]",
      "method": "DELETE",
      "description": "Unsubscribe"
    },
    {
      "path": "users",
      "method": "GET",
      "description": "List active system users for assignee selection"
    },
    {
      "path": "widget/[checklist-id]",
      "method": "GET",
      "description": "Get upcoming items for the homescreen widget"
    },
    {
      "path": "checklists/[checklist-id]/ics",
      "method": "GET",
      "description": "List ICS feed links for a checklist (owner only)"
    },
    {
      "path": "checklists/[checklist-id]/ics",
      "method": "POST",
      "description": "Create an ICS feed link for a checklist (owner only)"
    },
    {
      "path": "checklists/[checklist-id]/ics/[link-id]",
      "method": "DELETE",
      "description": "Revoke an ICS feed link (owner only)"
    },
    {
      "path": "checklist/ics/[checklist-id]",
      "method": "GET",
      "description": "Serve ICS calendar data for a checklist (public, authenticated via key query parameter)"
    }
  ],
  "notificationTopics": [
    {
      "id": "item-due",
      "name": "Item Due Soon",
      "summary": "Sent daily for checklist items due today or tomorrow that are assigned to you or on a watched checklist",
      "ntfyTag": "calendar"
    }
  ],
  "agents": [
    {
      "name": "notifier",
      "label": "Nightly Notifier",
      "description": "Sends system notifications for checklist items due today or tomorrow",
      "cron": "0 6 * * *"
    }
  ],
  "applets": [
    {
      "id": "main",
      "label": "Taskboards",
      "description": "Main checklisting application",
      "target": "app",
      "component": "Taskboard"
    },
    {
      "id": "widget",
      "label": "Checklist",
      "description": "Shows upcoming items for a single checklist on the homescreen",
      "target": "home",
      "component": "TaskboardWidget",
      "settings": [
        {
          "name": "checklistId",
          "label": "Checklist ID",
          "type": "text",
          "placeholder": "Paste the checklist ID here"
        },
        {
          "name": "lookahead",
          "label": "Show items due within",
          "type": "select",
          "defaultValue": "none",
          "options": [
            { "value": "24", "label": "24 hours" },
            { "value": "48", "label": "48 hours" },
            { "value": "72", "label": "72 hours" },
            { "value": "168", "label": "1 week" },
            { "value": "none", "label": "All incomplete" }
          ]
        },
        {
          "name": "maxItems",
          "label": "Items to display",
          "type": "number",
          "defaultValue": "5",
          "placeholder": "5"
        },
        {
          "name": "displayDatelessItems",
          "label": "Display dateless items",
          "type": "select",
          "defaultValue": "false",
          "options": [
            { "value": "false", "label": "Hidden by default" },
            { "value": "true", "label": "Shown by default" }
          ]
        }
      ]
    }
  ]
}
